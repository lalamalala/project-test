# ─────────────────────────────────────────────────────────────────────────────
# QuickPizza k6 test – environment variables
# Copy this file to .env and fill in values as needed.
# Pass variables to k6 with the -e flag:
#   k6 run -e BASE_URL=https://quickpizza.grafana.com tests/quickpizza.js
# ─────────────────────────────────────────────────────────────────────────────

# Target server (no trailing slash)
BASE_URL=https://quickpizza.grafana.com

# ── Load shape ────────────────────────────────────────────────────────────────
# VUs during the warm-up and base-load stages
BASE_VUS=5

# VUs at peak load
PEAK_VUS=20

# Duration of each ramp stage  (e.g. 30s, 1m)
RAMP_TIME=30s

# Duration of each steady-state stage  (e.g. 1m, 2m, 5m)
STEADY_TIME=2m
